{
  "name": "sharebite-backend",
  "version": "1.0.0",
  "description": "ShareBite Backend API with Express.js and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node -e \"require('dotenv').config(); require('./db/migrate')().then(()=>{console.log('Migration completed'); process.exit(0)}).catch(err=>{console.error(err); process.exit(1)})\"",
    "seed": "node -e \"require('dotenv').config(); require('./seedDemo')().then(()=>{console.log('Seed completed'); process.exit(0)}).catch(err=>{console.error(err); process.exit(1)})\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
